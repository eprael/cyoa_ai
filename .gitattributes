# Normalize line endings: store text as LF in the repo, check out native on each OS.
# Settles the "LF will be replaced by CRLF" warnings on Windows.
* text=auto

# Keep shell/CLI scripts as LF even on Windows checkouts.
*.sh   text eol=lf
*.cmd  text eol=crlf

# Treat common binaries as binary (no EOL munging, no diff noise).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.mp4  binary
*.woff binary
*.woff2 binary
